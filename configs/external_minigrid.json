{
  "experiment_name": "external_minigrid_validation",
  "output_dir": "results/external_minigrid",
  "runtime": {
    "torch_threads": 1,
    "torch_interop_threads": 1,
    "workers": 8
  },
  "seeds": [200, 201, 202, 203, 204, 205, 206, 207, 208, 209],
  "evaluation": {
    "interval_steps": 5000,
    "episodes": 30
  },
  "analysis": {
    "primary_metric": "return_auc",
    "planned_contrasts": [
      {"name": "count_vs_dqn", "left": "count_gated_tau_20", "right": "dqn", "metric": "return_auc"},
      {"name": "reliability_vs_dqn", "left": "reliability_gated", "right": "dqn", "metric": "return_auc"}
    ]
  },
  "envs": [
    {
      "name": "MiniGrid-Empty-5x5",
      "id": "MiniGrid-Empty-5x5-v0",
      "observation": "fully_observable_image",
      "training_steps": 20000,
      "max_steps": 200,
      "success_mode": "positive_terminal"
    }
  ],
  "agents": [
    {
      "name": "tabular",
      "kind": "tabular",
      "params": {"tabular_learning_rate": 0.2, "epsilon_decay_steps": 16000}
    },
    {
      "name": "dqn",
      "kind": "dqn",
      "params": {"learning_rate": 0.001, "batch_size": 32, "replay_warmup": 256, "train_frequency": 16, "target_update_interval": 500, "hidden_size": 64, "epsilon_decay_steps": 16000}
    },
    {
      "name": "count_gated_tau_20",
      "kind": "count_gated",
      "params": {"learning_rate": 0.001, "tabular_learning_rate": 0.2, "batch_size": 32, "replay_warmup": 256, "train_frequency": 16, "target_update_interval": 500, "hidden_size": 64, "tau": 20, "epsilon_decay_steps": 16000}
    },
    {
      "name": "reliability_gated",
      "kind": "reliability_gated",
      "params": {"learning_rate": 0.001, "tabular_learning_rate": 0.2, "batch_size": 32, "replay_warmup": 256, "train_frequency": 16, "target_update_interval": 500, "hidden_size": 64, "reliability_beta": 0.05, "reliability_prior_strength": 10, "epsilon_decay_steps": 16000}
    }
  ]
}
