{
  "experiment_name": "posthoc_development_selected_dqn_minigrid",
  "output_dir": "results/dqn_validation_minigrid",
  "runtime": {
    "torch_threads": 1,
    "torch_interop_threads": 1,
    "workers": 6
  },
  "seeds": [200, 201, 202, 203, 204, 205, 206, 207, 208, 209],
  "evaluation": {
    "interval_steps": 5000,
    "episodes": 30
  },
  "analysis": {
    "primary_metric": "return_auc",
    "analysis_status": "post_hoc_development_selected_validation",
    "selection_rule": "Lowest average environment rank by mean return AUC on development seeds 0-4 across the four compact environments and MiniGrid.",
    "planned_contrasts": []
  },
  "envs": [
    {
      "name": "MiniGrid-Empty-5x5",
      "id": "MiniGrid-Empty-5x5-v0",
      "observation": "fully_observable_image",
      "training_steps": 20000,
      "max_steps": 200,
      "success_mode": "positive_terminal"
    }
  ],
  "agents": [
    {
      "name": "development_selected_dqn",
      "kind": "dqn",
      "params": {
        "learning_rate": 0.0003,
        "batch_size": 32,
        "replay_warmup": 256,
        "train_frequency": 16,
        "target_update_interval": 500,
        "hidden_size": 64,
        "epsilon_decay_steps": 16000
      }
    }
  ]
}
