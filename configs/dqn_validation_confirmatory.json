{
  "experiment_name": "posthoc_development_selected_dqn_confirmatory",
  "output_dir": "results/dqn_validation_confirmatory",
  "runtime": {
    "torch_threads": 1,
    "torch_interop_threads": 1,
    "workers": 8
  },
  "seeds": [100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 111, 112, 113, 114, 115, 116, 117, 118, 119, 120, 121, 122, 123, 124, 125, 126, 127, 128, 129],
  "evaluation": {
    "interval_steps": 2000,
    "episodes": 30
  },
  "analysis": {
    "primary_metric": "return_auc",
    "analysis_status": "post_hoc_development_selected_validation",
    "selection_rule": "Lowest average environment rank by mean return AUC on development seeds 0-4 across the four compact environments and MiniGrid.",
    "planned_contrasts": []
  },
  "envs": [
    {
      "name": "FourRooms-7-unseen-goals",
      "id": "StructuredFourRooms-v0",
      "kwargs": {"size": 7, "goal_split": "train", "slip_probability": 0.0, "max_steps": 100},
      "eval_kwargs": {"goal_split": "test"},
      "training_steps": 8000,
      "max_steps": 100,
      "success_mode": "positive_terminal"
    },
    {
      "name": "FourRooms-9-slip-unseen-goals",
      "id": "StructuredFourRooms-v0",
      "kwargs": {"size": 9, "goal_split": "train", "slip_probability": 0.1, "max_steps": 160},
      "eval_kwargs": {"goal_split": "test"},
      "training_steps": 12000,
      "max_steps": 160,
      "success_mode": "positive_terminal"
    },
    {
      "name": "FrozenLake-v1",
      "id": "FrozenLake-v1",
      "kwargs": {"is_slippery": true},
      "training_steps": 10000,
      "max_steps": 100,
      "success_mode": "positive_terminal"
    },
    {
      "name": "CliffWalking-v1",
      "id": "CliffWalking-v1",
      "training_steps": 10000,
      "max_steps": 500,
      "success_mode": "terminated"
    }
  ],
  "agents": [
    {
      "name": "development_selected_dqn",
      "kind": "dqn",
      "params": {
        "learning_rate": 0.0003,
        "batch_size": 32,
        "replay_warmup": 256,
        "train_frequency": 16,
        "target_update_interval": 500,
        "hidden_size": 64,
        "epsilon_decay_steps": 8000
      }
    }
  ]
}
