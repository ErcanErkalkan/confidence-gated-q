{
  "experiment_name": "mlwa_dqn_tuning_development",
  "output_dir": "results/dqn_tuning_development",
  "runtime": {
    "torch_threads": 1,
    "torch_interop_threads": 1,
    "workers": 8
  },
  "seeds": [0, 1, 2, 3, 4],
  "evaluation": {
    "interval_steps": 2500,
    "episodes": 20
  },
  "analysis": {
    "primary_metric": "return_auc",
    "analysis_status": "development_model_selection",
    "selection_rule": "Select the lowest mean environment rank in return_auc across all seven development environments. Break ties by lower worst-environment rank, then fewer gradient updates, then lexicographic agent name.",
    "planned_contrasts": []
  },
  "envs": [
    {
      "name": "FrozenLake-4x4-slippery",
      "id": "FrozenLake-v1",
      "kwargs": {"map_name": "4x4", "is_slippery": true},
      "training_steps": 10000,
      "max_steps": 100,
      "success_mode": "positive_terminal"
    },
    {
      "name": "FrozenLake-8x8-slippery",
      "id": "FrozenLake-v1",
      "kwargs": {"map_name": "8x8", "is_slippery": true},
      "training_steps": 20000,
      "max_steps": 300,
      "success_mode": "positive_terminal"
    },
    {
      "name": "CliffWalking-v1",
      "id": "CliffWalking-v1",
      "training_steps": 10000,
      "max_steps": 500,
      "success_mode": "terminated"
    },
    {
      "name": "Taxi-v3-compatible",
      "id": "Taxi-v3",
      "training_steps": 20000,
      "max_steps": 300,
      "success_mode": "positive_terminal"
    },
    {
      "name": "FourRooms-7-unseen-goals",
      "id": "StructuredFourRooms-v0",
      "kwargs": {"size": 7, "goal_split": "train", "slip_probability": 0.0, "max_steps": 100},
      "eval_kwargs": {"goal_split": "test"},
      "training_steps": 8000,
      "max_steps": 100,
      "success_mode": "positive_terminal"
    },
    {
      "name": "FourRooms-9-slip-unseen-goals",
      "id": "StructuredFourRooms-v0",
      "kwargs": {"size": 9, "goal_split": "train", "slip_probability": 0.1, "max_steps": 160},
      "eval_kwargs": {"goal_split": "test"},
      "training_steps": 12000,
      "max_steps": 160,
      "success_mode": "positive_terminal"
    },
    {
      "name": "FourRooms-11-slip-unseen-goals",
      "id": "StructuredFourRooms-v0",
      "kwargs": {"size": 11, "goal_split": "train", "slip_probability": 0.1, "max_steps": 220},
      "eval_kwargs": {"goal_split": "test"},
      "training_steps": 16000,
      "max_steps": 220,
      "success_mode": "positive_terminal"
    }
  ],
  "agents": [
    {
      "name": "vanilla_dqn_h64",
      "kind": "dqn",
      "params": {"double_dqn": false, "learning_rate": 0.001, "batch_size": 32, "replay_capacity": 50000, "replay_warmup": 256, "train_frequency": 16, "target_update_interval": 500, "hidden_size": 64, "epsilon_decay_steps": 12000}
    },
    {
      "name": "vanilla_dqn_h128",
      "kind": "dqn",
      "params": {"double_dqn": false, "learning_rate": 0.001, "batch_size": 32, "replay_capacity": 50000, "replay_warmup": 256, "train_frequency": 16, "target_update_interval": 500, "hidden_size": 128, "epsilon_decay_steps": 12000}
    },
    {
      "name": "vanilla_dqn_lr3e4_h128",
      "kind": "dqn",
      "params": {"double_dqn": false, "learning_rate": 0.0003, "batch_size": 32, "replay_capacity": 50000, "replay_warmup": 256, "train_frequency": 16, "target_update_interval": 500, "hidden_size": 128, "epsilon_decay_steps": 12000}
    },
    {
      "name": "vanilla_dqn_buffer100k",
      "kind": "dqn",
      "params": {"double_dqn": false, "learning_rate": 0.0003, "batch_size": 32, "replay_capacity": 100000, "replay_warmup": 512, "train_frequency": 16, "target_update_interval": 500, "hidden_size": 128, "epsilon_decay_steps": 12000}
    },
    {
      "name": "vanilla_dqn_target250",
      "kind": "dqn",
      "params": {"double_dqn": false, "learning_rate": 0.0003, "batch_size": 32, "replay_capacity": 100000, "replay_warmup": 512, "train_frequency": 16, "target_update_interval": 250, "hidden_size": 128, "epsilon_decay_steps": 12000}
    },
    {
      "name": "vanilla_dqn_target1000",
      "kind": "dqn",
      "params": {"double_dqn": false, "learning_rate": 0.0003, "batch_size": 32, "replay_capacity": 100000, "replay_warmup": 512, "train_frequency": 16, "target_update_interval": 1000, "hidden_size": 128, "epsilon_decay_steps": 12000}
    },
    {
      "name": "double_dqn_lr3e4_h128",
      "kind": "double_dqn",
      "params": {"double_dqn": true, "learning_rate": 0.0003, "batch_size": 32, "replay_capacity": 100000, "replay_warmup": 512, "train_frequency": 16, "target_update_interval": 1000, "hidden_size": 128, "epsilon_decay_steps": 12000}
    }
  ]
}
