  "analysis": {
    "primary_metric": "return_auc",
    "analysis_status": "preregistered_full_reviewer_protocol_not_executed_in_deposited_results",
    "planned_contrasts": [
      {
        "name": "dueling_double_dqn_vs_validated_dqn",
        "left": "dueling_double_dqn",
        "right": "validated_dqn",
        "metric": "return_auc"
      },
      {
        "name": "a2c_vs_validated_dqn",
        "left": "a2c_actor_critic",
        "right": "validated_dqn",
        "metric": "return_auc"
      }
    ],
    "validation_scope": "30-seed reviewer-response protocol for DQN, dueling Double-DQN, and A2C; execute before making stronger-neural-baseline performance claims."
  },
  "envs": [
    {
      "name": "FourRooms-7-unseen-goals",
      "id": "StructuredFourRooms-v0",
      "kwargs": {
        "size": 7,
        "goal_split": "train",
        "slip_probability": 0.0,
        "max_steps": 100
      },
      "eval_kwargs": {
        "goal_split": "test"
      },
      "training_steps": 12000,
      "max_steps": 120,
      "success_mode": "positive_terminal"
    },
    {
      "name": "ApplicationNavigation-deployment-goal-shift",
      "id": "ApplicationNavigationSupportShift-v0",
      "kwargs": {
        "goal_split": "train",
        "slip_probability": 0.05,
        "max_steps": 120
      },
      "eval_kwargs": {
        "goal_split": "deployment"
      },
      "training_steps": 12000,
      "max_steps": 120,
      "success_mode": "positive_terminal"
    }
  ],
  "agents": [
    {
      "name": "validated_dqn",
      "kind": "dqn",
      "params": {
        "double_dqn": false,
        "learning_rate": 0.0003,
        "batch_size": 32,
        "replay_capacity": 100000,
        "replay_warmup": 512,
        "train_frequency": 16,
        "target_update_interval": 500,
        "hidden_size": 128,
        "epsilon_decay_steps": 10000
      }
    },
    {
      "name": "dueling_double_dqn",
      "kind": "dueling_dqn",
      "params": {
        "double_dqn": true,
        "network_architecture": "dueling_mlp",
        "learning_rate": 0.0003,
        "batch_size": 32,
        "replay_capacity": 100000,
        "replay_warmup": 512,
        "train_frequency": 16,
        "target_update_interval": 500,
        "hidden_size": 128,
        "epsilon_decay_steps": 10000
      }
    },
    {
      "name": "a2c_actor_critic",
      "kind": "a2c",
      "params": {
        "learning_rate": 0.0003,
        "hidden_size": 128,
        "a2c_value_coef": 0.5,
        "a2c_entropy_coef": 0.01,
        "epsilon_decay_steps": 10000,
        "batch_size": 32,
        "replay_warmup": 512,
        "train_frequency": 16
      }
    }
  ]
}